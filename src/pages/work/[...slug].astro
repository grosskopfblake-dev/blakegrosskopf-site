---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import KillChain from '../../components/KillChain.astro';
import ImageSlot from '../../components/ImageSlot.astro';

export async function getStaticPaths() {
  const work = (await getCollection('work', ({ data }) => !data.draft)).sort(
    (a, b) => a.data.order - b.data.order,
  );
  return work.map((entry, i) => ({
    params: { slug: entry.id },
    props: { entry, prev: work[i - 1] ?? null, next: work[i + 1] ?? null },
  }));
}

const { entry, prev, next } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
const statusLabel = data.status === 'in-progress' ? 'In progress' : data.status === 'ongoing' ? 'Ongoing' : 'Complete';
const kindLabel: Record<string, string> = { repo: 'Repository', writeup: 'Write-up', external: 'Reference', demo: 'Demo' };
---
<Base title={data.title} description={data.summary} image={data.heroImage ?? '/og.svg'} article>
  <article class="cs">
    <!-- header -->
    <header class="section cs-head-sec">
      <div class="container">
        <a href="/work/" class="backlink"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6"/></svg> All work</a>
        <p class="eyebrow eyebrow--rule cs-eyebrow">
          <span>{data.lane}</span>
          <span class="cs-dot" data-status={data.status}>{statusLabel}</span>
          <time class="cs-date" datetime={data.date.toISOString().slice(0, 10)}>{fmtDate(data.date)}</time>
        </p>
        <h1 class="cs-title">{data.title}</h1>
        <p class="cs-summary serif">{data.summary}</p>
        {data.links.length > 0 && (
          <div class="cs-links">
            {data.links.map((l: any) => (
              <a href={l.url} class="btn" target="_blank" rel="noopener">
                {kindLabel[l.kind] ?? 'Link'}: {l.label}
                <svg class="arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M7 17L17 7M9 7h8v8"/></svg>
              </a>
            ))}
          </div>
        )}
      </div>
    </header>

    <!-- signature kill-chain -->
    {data.killchain.length > 0 && (
      <div class="container cs-chain">
        <KillChain steps={data.killchain} caption="Attack path" note={data.killchain.find((s: any) => s.live) ? 'pivotal step highlighted' : undefined} variant="hero" />
      </div>
    )}

    {data.heroImage && (
      <div class="container cs-hero-img">
        <ImageSlot src={data.heroImage} alt={data.heroAlt} ratio="21/9" loading="eager" />
      </div>
    )}

    <!-- body + facts -->
    <div class="container cs-grid">
      <div class="cs-main prose">
        <Content />
      </div>

      <aside class="cs-aside">
        <div class="facts">
          <p class="label">Engagement facts</p>
          <dl class="fact-list">
            <div><dt>Lane</dt><dd>{data.lane}</dd></div>
            <div><dt>Status</dt><dd>{statusLabel}</dd></div>
            <div><dt>Date</dt><dd><time datetime={data.date.toISOString().slice(0, 10)}>{fmtDate(data.date)}</time></dd></div>
            {data.role && <div><dt>Role</dt><dd>{data.role}</dd></div>}
            {data.timeframe && <div><dt>Timeframe</dt><dd>{data.timeframe}</dd></div>}
          </dl>
          {data.stack.length > 0 && (
            <div class="facts-stack">
              <p class="label">Stack</p>
              <div class="card-chips">{data.stack.map((s: string) => <span class="chip">{s}</span>)}</div>
            </div>
          )}
        </div>
      </aside>
    </div>

    <!-- findings -->
    {data.findings.length > 0 && (
      <section class="container cs-block" aria-labelledby="findings-h">
        <h2 id="findings-h" class="block-h"><span class="marker">A</span>Findings</h2>
        <div class="scroll-x findings-wrap">
          <table class="findings">
            <thead><tr><th scope="col">Severity</th><th scope="col">Finding</th><th scope="col">ATT&amp;CK</th><th scope="col">Recommendation</th></tr></thead>
            <tbody>
              {data.findings.map((f: any) => (
                <tr>
                  <td><span class:list={['sev', `sev--${f.severity}`]}>{f.severity}</span></td>
                  <td class="f-title">{f.title}</td>
                  <td class="mono f-mitre">{f.mitre ?? '—'}</td>
                  <td class="f-rec serif">{f.recommendation}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- MITRE block -->
    {data.mitre.length > 0 && (
      <section class="container cs-block" aria-labelledby="mitre-h">
        <h2 id="mitre-h" class="block-h"><span class="marker">B</span>MITRE ATT&amp;CK</h2>
        <ul class="mitre-grid">
          {data.mitre.map((m: any) => (
            <li class="mitre-item">
              <span class="mitre-id mono">{m.id}</span>
              {m.name && <span class="mitre-name">{m.name}</span>}
              {m.tactic && <span class="mitre-tactic">{m.tactic}</span>}
            </li>
          ))}
        </ul>
      </section>
    )}

    <!-- takeaway -->
    {data.takeaway && (
      <section class="container cs-block">
        <div class="takeaway">
          <p class="label">What this demonstrates</p>
          <p class="takeaway-body serif">{data.takeaway}</p>
        </div>
      </section>
    )}

    <!-- prev / next -->
    <nav class="container cs-nav" aria-label="More work">
      {prev ? (
        <a href={`/work/${prev.id}/`} class="cs-nav-item cs-nav-prev">
          <span class="cs-nav-dir">← Previous</span>
          <span class="cs-nav-title">{prev.data.title}</span>
        </a>
      ) : <span></span>}
      {next && (
        <a href={`/work/${next.id}/`} class="cs-nav-item cs-nav-next">
          <span class="cs-nav-dir">Next →</span>
          <span class="cs-nav-title">{next.data.title}</span>
        </a>
      )}
    </nav>
  </article>
</Base>

<style>
  .cs-head-sec { padding-bottom: clamp(1.5rem, 4vw, 2.5rem); }
  .backlink { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--t-small); color: var(--fg-2); margin-bottom: 1.6rem; }
  .backlink:hover { color: var(--fg); }
  .backlink svg { width: 15px; height: 15px; }
  .cs-eyebrow { gap: 0.9rem; }
  .cs-dot { display: inline-flex; align-items: center; gap: 0.4rem; color: var(--fg-2); }
  .cs-dot::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: var(--sev-low); }
  .cs-dot[data-status='in-progress']::before { background: var(--sev-medium); }
  .cs-date { color: var(--fg-3); }
  .cs-title { margin-top: 1.1rem; max-width: 18ch; }
  .cs-summary { margin-top: 1.25rem; max-width: 60ch; font-size: clamp(1.15rem, 1rem + 0.7vw, 1.4rem); line-height: 1.5; color: var(--fg-2); }
  .cs-links { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-top: 1.6rem; }
  .cs-links .arw { width: 14px; height: 14px; }

  .cs-chain { margin-bottom: clamp(2rem, 5vw, 3rem); }
  .cs-hero-img { margin-bottom: clamp(2rem, 5vw, 3rem); }

  .cs-grid { display: grid; gap: 2.5rem; }
  @media (min-width: 900px) {
    .cs-grid { grid-template-columns: minmax(0, 1fr) 17rem; gap: 3.5rem; align-items: start; }
    .cs-aside { position: sticky; top: 84px; }
  }
  .facts { border: 1px solid var(--rule); border-radius: var(--r-lg); padding: 1.25rem; background: var(--surface); }
  .fact-list { margin: 0.9rem 0 0; display: grid; gap: 0.7rem; }
  .fact-list div { display: grid; grid-template-columns: 6rem 1fr; gap: 0.75rem; align-items: baseline; }
  .fact-list dt { font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); }
  .fact-list dd { margin: 0; font-size: var(--t-small); color: var(--fg); }
  .facts-stack { margin-top: 1.2rem; padding-top: 1.2rem; border-top: 1px solid var(--rule); }
  .facts-stack .card-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.6rem; }

  .cs-block { margin-top: clamp(2.5rem, 6vw, 4rem); }
  .block-h { font-size: var(--t-h3); margin-bottom: 1.4rem; }
  .block-h .marker { font-size: 0.55em; vertical-align: 0.4em; }

  .findings { width: 100%; border-collapse: collapse; font-family: var(--font-display); }
  .findings thead th { font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); text-align: left; padding: 0 0.9rem 0.7rem; border-bottom: 1px solid var(--rule); white-space: nowrap; }
  .findings td { padding: 0.9rem 0.9rem; border-bottom: 1px solid var(--rule); vertical-align: top; font-size: var(--t-small); }
  .findings .f-title { font-weight: 500; min-width: 12rem; }
  .findings .f-mitre { color: var(--fg-2); white-space: nowrap; }
  .findings .f-rec { color: var(--fg-2); min-width: 16rem; font-size: 0.98rem; }
  .findings-wrap { border-radius: var(--r); }

  .mitre-grid { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; grid-template-columns: 1fr; }
  @media (min-width: 620px) { .mitre-grid { grid-template-columns: 1fr 1fr; } }
  .mitre-item { display: grid; grid-template-columns: 6.5rem 1fr; gap: 0.4rem 1rem; align-items: baseline; padding: 0.7rem 0.9rem; border: 1px solid var(--rule); border-radius: var(--r); }
  .mitre-id { color: var(--verm-hot); font-weight: 500; }
  .mitre-name { font-size: var(--t-small); }
  .mitre-tactic { grid-column: 2; font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.06em; text-transform: uppercase; color: var(--fg-3); }

  .takeaway { border-left: 2px solid var(--verm); padding: 0.3rem 0 0.3rem 1.4rem; }
  .takeaway-body { font-size: clamp(1.2rem, 1rem + 1vw, 1.6rem); line-height: 1.45; margin-top: 0.7rem; max-width: 46ch; }

  .cs-nav { display: grid; gap: 1rem; margin-top: clamp(3rem, 7vw, 5rem); padding-top: 2rem; border-top: 1px solid var(--rule); grid-template-columns: 1fr 1fr; }
  .cs-nav-item { display: flex; flex-direction: column; gap: 0.4rem; padding: 1.1rem 1.2rem; border: 1px solid var(--rule); border-radius: var(--r-lg); transition: border-color var(--dur-1) var(--ease); }
  .cs-nav-item:hover { border-color: var(--verm); }
  .cs-nav-next { text-align: right; }
  .cs-nav-dir { font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.1em; text-transform: uppercase; color: var(--verm-hot); }
  .cs-nav-title { font-family: var(--font-display); font-weight: 500; font-size: 1.05rem; letter-spacing: -0.01em; }
  @media (max-width: 560px) { .cs-nav { grid-template-columns: 1fr; } .cs-nav-next { text-align: left; } }
</style>
