---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import WorkCard from '../../components/WorkCard.astro';

const work = (await getCollection('work', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<Base title="Work" description="Case studies: cloud and enterprise attack paths, built and broken end-to-end, with the defenses that stop them.">
  <section class="section">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="eyebrow eyebrow--rule">Case studies</p>
        <h1>Work</h1>
        <p class="page-lead serif">Each of these is a self-directed project on infrastructure I own or am authorized to test — built, broken, and documented end to end. Report structure throughout: scope, recon, finding, impact, remediation, mapped to MITRE ATT&amp;CK.</p>
      </header>
      <div class="work-list">
        {work.map((w, i) => (
          <div data-reveal style={`--reveal-delay:${(i % 3) * 80}ms`}>
            <WorkCard slug={w.id} data={w.data} featured={w.data.featured} />
          </div>
        ))}
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 62ch; margin-bottom: 2.75rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-lead { margin-top: 1.1rem; color: var(--fg-2); font-size: 1.2rem; line-height: 1.55; }
  .work-list { display: grid; gap: 1.25rem; }
  @media (min-width: 860px) {
    .work-list { grid-template-columns: 1fr 1fr; }
    .work-list > :global([data-reveal]:has(.card--featured)) { grid-column: 1 / -1; }
  }
</style>
