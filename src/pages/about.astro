---
import Base from '../layouts/Base.astro';
import CertSpine from '../components/CertSpine.astro';
import { site } from '../lib/site';

const WORK = '/work/operation-vermillion-drift/';
const skills = [
  { skill: 'Azure attack paths', detail: 'Public exposure → IMDS / managed-identity abuse → storage, secrets, and subscription-level control', href: WORK, evLabel: 'Vermillion Drift' },
  { skill: 'Cloud range building (Terraform)', detail: 'Standing up real, misconfigured cloud environments as IaC — and troubleshooting live deployments', href: WORK, evLabel: 'Vermillion Drift' },
  { skill: 'Active Directory enumeration & priv-esc', detail: 'PowerShell and BloodHound Enterprise — mapping privilege-escalation paths across a Windows domain', href: site.resume, evLabel: 'Resume' },
  { skill: 'Threat-based risk assessment', detail: 'MITRE ATT&CK / NIST-aligned methodology; phishing triage at enterprise scale', href: site.resume, evLabel: 'Resume' },
  { skill: 'ATT&CK mapping & detection', detail: 'Every finding mapped to a technique and paired with the control or detection that breaks it', href: WORK, evLabel: 'Vermillion Drift' },
  { skill: 'Offensive tooling (Python)', detail: 'stdlib-first — from captured traffic to a working primitive', href: WORK, evLabel: 'Vermillion Drift' },
];
---
<Base title="About" description="Blake Grosskopf — aspiring red teamer focused on cloud and enterprise attack paths.">
  <section class="section">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="eyebrow eyebrow--rule">About</p>
        <h1>Blake Grosskopf</h1>
        <p class="page-lead serif">{site.role}.</p>
      </header>

      <div class="about-grid">
        <div class="about-bio prose" data-reveal>
          <p>I'm an aspiring red teamer working <strong>cloud and enterprise attack paths</strong>. The throughline in everything I do: I don't just point tools at someone else's target — I <strong>build the environment myself</strong>, break in from the outside, then write the defense that would've stopped me.</p>
          <p>That comes from a <strong>software-engineering background</strong> — the instinct underneath all of it is building. I like taking something apart to see how it works, then turning that into a solution: a script, a small tool, a primitive, in Python or whatever fits.</p>
          <p>It got sharper on the job. As a returning cybersecurity intern on a large enterprise's security team, I ran a MITRE/NIST-aligned, threat-based risk assessment, mapped Active Directory privilege-escalation paths with PowerShell, and triaged reported phishing at scale — the defensive foundation under the offensive work here.</p>
          <p>On the cloud side I chain real Azure attack paths from public exposure to subscription-level control, standing the range up in Terraform and fighting the constraints of doing it on a locked-down subscription. Right now I'm focused on <strong>cloud and AI security</strong> and pen testing.</p>
          <p>Everything here is self-directed research on infrastructure I own or am cleared to test, kept dual-use: methodology, ATT&amp;CK mapping, and hardening. The runnable tooling stays private — the understanding and the defenses are what I publish.</p>
        </div>

        <aside class="about-side" data-reveal style="--reveal-delay:80ms">
          <div class="side-card">
            <p class="label">Focus</p>
            <ul class="focus-list">
              <li>Cloud penetration testing (Azure)</li>
              <li>Red team operations</li>
              <li>Active Directory attack paths</li>
              <li>Detection engineering (dual-use)</li>
            </ul>
          </div>
        </aside>
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">01</span>Skills, and the evidence</h2>
        <div class="scroll-x">
          <table class="skills">
            <thead><tr><th scope="col">Capability</th><th scope="col">What it covers</th><th scope="col">Evidenced by</th></tr></thead>
            <tbody>
              {skills.map((s) => (
                <tr>
                  <td class="sk-name">{s.skill}</td>
                  <td class="sk-detail serif">{s.detail}</td>
                  <td>{s.href ? <a class="sk-ev" href={s.href}>{s.evLabel} →</a> : <span class="sk-none">—</span>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">02</span>Cert spine</h2>
        <CertSpine />
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">03</span>Elsewhere</h2>
        <div class="hero-cta">
          <a href="/contact/" class="btn btn--primary">Contact <svg class="arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href={site.socials.github} class="btn" target="_blank" rel="noopener">GitHub</a>
          <a href={site.socials.linkedin} class="btn" target="_blank" rel="noopener">LinkedIn</a>
          <a href={site.resume} class="btn">Resume ↓</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 60ch; margin-bottom: 2.5rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-lead { margin-top: 0.8rem; color: var(--fg-2); font-size: 1.25rem; }
  .about-grid { display: grid; gap: 2.5rem; }
  @media (min-width: 880px) { .about-grid { grid-template-columns: minmax(0,1fr) 15rem; gap: 3.5rem; align-items: start; } }
  .about-bio.prose { max-width: 64ch; }
  .side-card { border: 1px solid var(--rule); border-radius: var(--r-lg); padding: 1.25rem; background: var(--surface); }
  .focus-list { list-style: none; margin: 0.8rem 0 0; padding: 0; display: grid; gap: 0.55rem; font-size: var(--t-small); }
  .focus-list li { display: flex; align-items: center; gap: 0.55rem; }
  .focus-list li::before { content: ""; width: 6px; height: 6px; border-radius: 1px; background: var(--verm); transform: rotate(45deg); flex: none; }
  .about-block { margin-top: clamp(2.75rem, 6vw, 4rem); }
  .block-h { font-size: var(--t-h3); margin-bottom: 1.4rem; }
  .block-h .marker { font-size: 0.5em; vertical-align: 0.5em; }
  .skills { width: 100%; border-collapse: collapse; font-family: var(--font-display); }
  .skills th { font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); text-align: left; padding: 0 0.9rem 0.7rem; border-bottom: 1px solid var(--rule); white-space: nowrap; }
  .skills td { padding: 0.95rem 0.9rem; border-bottom: 1px solid var(--rule); vertical-align: top; font-size: var(--t-small); }
  .sk-name { font-weight: 500; min-width: 13rem; }
  .sk-detail { color: var(--fg-2); min-width: 15rem; font-size: 1rem; }
  .sk-ev { font-family: var(--font-mono); font-size: var(--t-small); color: var(--verm-hot); white-space: nowrap; }
  .sk-ev:hover { text-decoration: underline; text-underline-offset: 3px; }
  .sk-none { font-family: var(--font-mono); font-size: var(--t-small); color: var(--fg-3); }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .hero-cta .arw { width: 15px; height: 15px; }

  /* Mobile: the skills table becomes stacked cards so the evidence column is
     never hidden behind a horizontal scroll. */
  @media (max-width: 620px) {
    .scroll-x { overflow-x: visible; }
    .skills, .skills tbody, .skills tr, .skills td { display: block; width: 100%; }
    .skills thead { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0,0,0,0); }
    .skills tr {
      border: 1px solid var(--rule); border-radius: var(--r-lg);
      padding: 0.9rem 1rem; margin-bottom: 0.75rem;
    }
    .skills td { border: 0; padding: 0; min-width: 0; }
    .sk-name { font-size: 1.02rem; margin-bottom: 0.35rem; }
    .sk-detail { font-size: 0.98rem; margin-bottom: 0.55rem; }
    .sk-ev { font-size: var(--t-small); }
  }
</style>
