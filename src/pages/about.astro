---
import Base from '../layouts/Base.astro';
import CertSpine from '../components/CertSpine.astro';
import { site } from '../lib/site';

const skills = [
  { skill: 'Azure cloud penetration testing', detail: 'SSRF, IMDS, managed-identity abuse, storage & secret looting', ev: 'operation-vermillion-drift', evLabel: 'Vermillion Drift' },
  { skill: 'Infrastructure-as-Code (Terraform)', detail: 'Provisioning ranges + real-world deployment troubleshooting', ev: 'operation-vermillion-drift', evLabel: 'Vermillion Drift' },
  { skill: 'Auth-protocol reverse engineering', detail: 'OAuth 2.0 / OIDC / PKCE, Okta OIE / IDX sign-in flows', ev: 'okta-oie-credential-oracle', evLabel: 'Okta OIE Oracle' },
  { skill: 'Offensive tool development', detail: 'Python, stdlib-first, from captured traffic to working primitive', ev: 'okta-oie-credential-oracle', evLabel: 'Okta OIE Oracle' },
  { skill: 'ARM REST API fluency', detail: 'Operating clouds through az rest when the CLI breaks', ev: 'operation-vermillion-drift', evLabel: 'Vermillion Drift' },
  { skill: 'Dual-use / defensive translation', detail: 'MITRE ATT&CK mapping, detections, and tenant hardening', ev: 'okta-oie-credential-oracle', evLabel: 'both projects' },
];
---
<Base title="About" description="Blake Grosskopf — independent offensive-security researcher focused on cloud and identity.">
  <section class="section">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="eyebrow eyebrow--rule">About</p>
        <h1>Blake Grosskopf</h1>
        <p class="page-lead serif">{site.role}.</p>
      </header>

      <div class="about-grid">
        <div class="about-bio prose" data-reveal>
          <p>I'm an independent offensive-security researcher working the seam where <strong>cloud and identity</strong> meet. My work has one throughline: I don't just run tools against someone else's target — I <strong>build the range myself</strong>, break it from an external attacker's position, and then write the defense that would have stopped me.</p>
          <p>That plays out two ways. On the cloud side, I chain real Azure attack paths from anonymous public exposure to subscription-level control, and I've fought the platform constraints of doing that on a locked-down subscription. On the identity side, I reverse-engineer SaaS authentication flows from captured traffic into precise models of how they work — and make deliberate calls about what to publish and what to withhold.</p>
          <p>Everything on this site is self-directed research on infrastructure I own or am authorized to test, framed dual-use: methodology, MITRE ATT&amp;CK mapping, and hardening. The runnable offensive tooling stays private; the understanding and the defenses are what I share.</p>
        </div>

        <aside class="about-side" data-reveal style="--reveal-delay:80ms">
          <div class="side-card">
            <p class="label">Focus</p>
            <ul class="focus-list">
              <li>Cloud penetration testing (Azure)</li>
              <li>Red team operations</li>
              <li>Identity &amp; SaaS security</li>
              <li>Detection engineering (dual-use)</li>
            </ul>
          </div>
        </aside>
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">01</span>Skills, and the evidence</h2>
        <div class="scroll-x">
          <table class="skills">
            <thead><tr><th scope="col">Capability</th><th scope="col">What it covers</th><th scope="col">Evidenced by</th></tr></thead>
            <tbody>
              {skills.map((s) => (
                <tr>
                  <td class="sk-name">{s.skill}</td>
                  <td class="sk-detail serif">{s.detail}</td>
                  <td><a class="sk-ev" href={`/work/${s.ev}/`}>{s.evLabel} →</a></td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">02</span>Cert spine</h2>
        <CertSpine />
      </div>

      <div class="about-block" data-reveal>
        <h2 class="block-h"><span class="marker">03</span>Elsewhere</h2>
        <div class="hero-cta">
          <a href="/contact/" class="btn btn--primary">Contact <svg class="arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg></a>
          <a href={site.socials.github} class="btn" target="_blank" rel="noopener">GitHub</a>
          <a href={site.socials.linkedin} class="btn" target="_blank" rel="noopener">LinkedIn</a>
          <a href={site.resume} class="btn">Résumé ↓</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 60ch; margin-bottom: 2.5rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-lead { margin-top: 0.8rem; color: var(--fg-2); font-size: 1.25rem; }
  .about-grid { display: grid; gap: 2.5rem; }
  @media (min-width: 880px) { .about-grid { grid-template-columns: minmax(0,1fr) 15rem; gap: 3.5rem; align-items: start; } }
  .about-bio.prose { max-width: 64ch; }
  .side-card { border: 1px solid var(--rule); border-radius: var(--r-lg); padding: 1.25rem; background: var(--surface); }
  .focus-list { list-style: none; margin: 0.8rem 0 0; padding: 0; display: grid; gap: 0.55rem; font-size: var(--t-small); }
  .focus-list li { display: flex; align-items: center; gap: 0.55rem; }
  .focus-list li::before { content: ""; width: 6px; height: 6px; border-radius: 1px; background: var(--verm); transform: rotate(45deg); flex: none; }
  .about-block { margin-top: clamp(2.75rem, 6vw, 4rem); }
  .block-h { font-size: var(--t-h3); margin-bottom: 1.4rem; }
  .block-h .marker { font-size: 0.5em; vertical-align: 0.5em; }
  .skills { width: 100%; border-collapse: collapse; font-family: var(--font-display); }
  .skills th { font-family: var(--font-mono); font-size: var(--t-micro); letter-spacing: 0.1em; text-transform: uppercase; color: var(--fg-3); text-align: left; padding: 0 0.9rem 0.7rem; border-bottom: 1px solid var(--rule); white-space: nowrap; }
  .skills td { padding: 0.95rem 0.9rem; border-bottom: 1px solid var(--rule); vertical-align: top; font-size: var(--t-small); }
  .sk-name { font-weight: 500; min-width: 13rem; }
  .sk-detail { color: var(--fg-2); min-width: 15rem; font-size: 1rem; }
  .sk-ev { font-family: var(--font-mono); font-size: var(--t-small); color: var(--verm-hot); white-space: nowrap; }
  .sk-ev:hover { text-decoration: underline; text-underline-offset: 3px; }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .hero-cta .arw { width: 15px; height: 15px; }
</style>
