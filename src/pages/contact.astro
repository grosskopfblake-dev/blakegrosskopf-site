---
import Base from '../layouts/Base.astro';
import { site } from '../lib/site';

const channels = [
  { label: 'Email', value: site.email, href: `mailto:${site.email}`, note: 'Best for roles & collaboration', ext: false },
  { label: 'GitHub', value: site.socials.githubHandle, href: site.socials.github, note: 'Code, skills & write-ups', ext: true },
  { label: 'LinkedIn', value: site.socials.linkedinHandle, href: site.socials.linkedin, note: 'Background & connections', ext: true },
];
---
<Base title="Contact" description="Get in touch with Blake Grosskopf — roles, collaboration, and research.">
  <section class="section">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="eyebrow eyebrow--rule">Contact</p>
        <h1>Let's talk.</h1>
        <p class="page-lead serif">Open to Cloud Penetration Tester, Red Team Operator, Offensive Security Engineer, and Identity Security roles — and to interesting research. Email is the surest way to reach me.</p>
      </header>

      <ul class="channels" data-reveal>
        {channels.map((c) => (
          <li>
            <a href={c.href} class="channel" target={c.ext ? '_blank' : undefined} rel={c.ext ? 'noopener' : undefined}>
              <span class="ch-label mono">{c.label}</span>
              <span class="ch-value">{c.value}</span>
              <span class="ch-note serif">{c.note}</span>
              <svg class="arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d={c.ext ? 'M7 17L17 7M9 7h8v8' : 'M5 12h14M13 6l6 6-6 6'}/></svg>
            </a>
          </li>
        ))}
      </ul>

      <div class="resume-row" data-reveal>
        <p class="serif">Want the one-pager?</p>
        <a href={site.resume} class="btn btn--primary">Download résumé ↓</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 56ch; margin-bottom: 2.75rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-lead { margin-top: 1.1rem; color: var(--fg-2); font-size: 1.2rem; line-height: 1.55; }
  .channels { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; max-width: 640px; }
  .channel {
    display: grid; grid-template-columns: 6.5rem 1fr auto; align-items: center; gap: 0.4rem 1.25rem;
    padding: 1.3rem 1.4rem; border: 1px solid var(--rule); border-radius: var(--r-lg); background: var(--surface);
    transition: border-color var(--dur-1) var(--ease), transform var(--dur-1) var(--ease);
  }
  .channel:hover { border-color: var(--verm); transform: translateY(-2px); }
  .channel:hover .arw { transform: translateX(3px); color: var(--verm-hot); }
  .ch-label { font-size: var(--t-micro); letter-spacing: 0.14em; text-transform: uppercase; color: var(--verm-hot); }
  .ch-value { font-family: var(--font-display); font-weight: 500; font-size: 1.15rem; letter-spacing: -0.01em; word-break: break-word; }
  .ch-note { grid-column: 2; color: var(--fg-3); font-size: 0.95rem; }
  .channel .arw { grid-row: 1 / 3; grid-column: 3; width: 18px; height: 18px; color: var(--fg-3); transition: transform var(--dur-1) var(--ease), color var(--dur-1) var(--ease); }
  .resume-row { display: flex; flex-wrap: wrap; align-items: center; gap: 1rem 1.5rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 1px solid var(--rule); }
  .resume-row p { color: var(--fg-2); font-size: 1.1rem; }
  @media (max-width: 520px) {
    .channel { grid-template-columns: 1fr auto; }
    .ch-label { grid-column: 1 / -1; }
    .ch-note { grid-column: 1 / -1; }
    .channel .arw { grid-row: 2; }
  }
</style>
