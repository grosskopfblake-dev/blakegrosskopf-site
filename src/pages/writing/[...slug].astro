---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { data } = entry;
const { Content } = await render(entry);
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

// Resolve related case studies (skip any that don't exist).
const related = (
  await Promise.all(
    data.related.map(async (slug: string) => {
      try { return await getEntry('work', slug); } catch { return null; }
    }),
  )
).filter(Boolean);
---
<Base title={data.title} description={data.description} article>
  <article class="section post">
    <div class="container narrow">
      <a href="/writing/" class="backlink"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M19 12H5M11 6l-6 6 6 6"/></svg> All writing</a>
      <p class="eyebrow eyebrow--rule post-meta">
        <time datetime={data.date.toISOString().slice(0, 10)}>{fmtDate(data.date)}</time>
        {data.updated && <span class="upd">updated <time datetime={data.updated.toISOString().slice(0, 10)}>{fmtDate(data.updated)}</time></span>}
      </p>
      <h1 class="post-h">{data.title}</h1>
      <p class="post-desc serif">{data.description}</p>
      {data.tags.length > 0 && <div class="post-tags">{data.tags.map((t: string) => <span class="chip">{t}</span>)}</div>}

      <div class="prose post-body">
        <Content />
      </div>

      {related.length > 0 && (
        <aside class="related">
          <p class="label">Related work</p>
          <ul>
            {related.map((r: any) => (
              <li>
                <a href={`/work/${r.id}/`} class="rel-row">
                  <span class="rel-lane mono">{r.data.lane}</span>
                  <span class="rel-title">{r.data.title}</span>
                  <svg class="arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
                </a>
              </li>
            ))}
          </ul>
        </aside>
      )}
    </div>
  </article>
</Base>

<style>
  .narrow { max-width: 760px; }
  .backlink { display: inline-flex; align-items: center; gap: 0.4rem; font-family: var(--font-mono); font-size: var(--t-small); color: var(--fg-2); margin-bottom: 1.6rem; }
  .backlink:hover { color: var(--fg); }
  .backlink svg { width: 15px; height: 15px; }
  .post-meta { gap: 0.9rem; }
  .upd { color: var(--fg-3); }
  .post-h { margin-top: 1rem; max-width: 22ch; }
  .post-desc { margin-top: 1.1rem; font-size: 1.3rem; line-height: 1.5; color: var(--fg-2); max-width: 60ch; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 1.2rem; }
  .post-body { margin-top: 2.5rem; max-width: none; }
  .related { margin-top: 3.5rem; padding-top: 1.6rem; border-top: 1px solid var(--rule); }
  .related ul { list-style: none; margin: 0.9rem 0 0; padding: 0; display: grid; gap: 0.6rem; }
  .rel-row { display: flex; align-items: center; gap: 1rem; padding: 1rem 1.1rem; border: 1px solid var(--rule); border-radius: var(--r-lg); transition: border-color var(--dur-1) var(--ease); }
  .rel-row:hover { border-color: var(--verm); }
  .rel-row:hover .arw { transform: translateX(3px); }
  .rel-lane { font-size: var(--t-micro); letter-spacing: 0.14em; text-transform: uppercase; color: var(--verm-hot); }
  .rel-title { font-family: var(--font-display); font-weight: 500; flex: 1; }
  .rel-row .arw { width: 15px; height: 15px; color: var(--verm-hot); transition: transform var(--dur-1) var(--ease); }
</style>
