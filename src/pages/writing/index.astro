---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => +b.data.date - +a.data.date,
);
const fmtDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---
<Base title="Writing" description="Field notes on cloud attack paths, red-team tradecraft, and the defenses that stop them.">
  <section class="section">
    <div class="container">
      <header class="page-head" data-reveal>
        <p class="eyebrow eyebrow--rule">Field notes</p>
        <h1>Writing</h1>
        <p class="page-lead serif">Focused lessons pulled from the work — the kind of thing I wish I'd found when I hit the wall myself.</p>
      </header>

      {posts.length === 0 ? (
        <p class="serif empty">First posts landing soon.</p>
      ) : (
        <ul class="post-list">
          {posts.map((p, i) => (
            <li data-reveal style={`--reveal-delay:${(i % 4) * 70}ms`}>
              <a href={`/writing/${p.id}/`} class="post-row">
                <time class="post-date mono" datetime={p.data.date.toISOString().slice(0, 10)}>{fmtDate(p.data.date)}</time>
                <span class="post-body">
                  <span class="post-title">{p.data.title}</span>
                  <span class="post-desc serif">{p.data.description}</span>
                  {p.data.tags.length > 0 && (
                    <span class="post-tags">{p.data.tags.map((t: string) => <span class="chip">{t}</span>)}</span>
                  )}
                </span>
                <svg class="arw post-arw" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</Base>

<style>
  .page-head { max-width: 60ch; margin-bottom: 2.5rem; }
  .page-head h1 { margin-top: 1rem; }
  .page-lead { margin-top: 1.1rem; color: var(--fg-2); font-size: 1.2rem; line-height: 1.55; }
  .empty { color: var(--fg-2); }
  .post-list { list-style: none; margin: 0; padding: 0; border-top: 1px solid var(--rule); }
  .post-row { display: grid; grid-template-columns: 7.5rem 1fr auto; align-items: start; gap: 1.25rem; padding: 1.6rem 0.25rem; border-bottom: 1px solid var(--rule); transition: padding var(--dur-2) var(--ease), background var(--dur-2) var(--ease); }
  .post-row:hover { padding-left: 0.9rem; padding-right: 0.9rem; background: var(--surface); }
  .post-row:hover .post-title { color: var(--verm-hot); }
  .post-row:hover .post-arw { transform: translateX(4px); }
  .post-date { font-size: var(--t-small); color: var(--fg-3); padding-top: 0.3rem; }
  .post-body { display: flex; flex-direction: column; gap: 0.4rem; min-width: 0; }
  .post-title { font-family: var(--font-display); font-weight: 500; font-size: 1.3rem; letter-spacing: -0.015em; transition: color var(--dur-1) var(--ease); }
  .post-desc { color: var(--fg-2); font-size: 1.05rem; line-height: 1.5; max-width: 62ch; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.3rem; }
  .post-arw { width: 16px; height: 16px; color: var(--verm-hot); transition: transform var(--dur-1) var(--ease); margin-top: 0.4rem; }
  @media (max-width: 600px) { .post-row { grid-template-columns: 1fr auto; } .post-date { grid-column: 1 / -1; padding-top: 0; } }
</style>
