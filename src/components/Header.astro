---
import { site } from '../lib/site';
const path = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? path === '/' : path.startsWith(href));
---
<header class="site-head">
  <div class="container head-in">
    <a href="/" class="wordmark" aria-label={`${site.name} — home`}>
      <img class="wm-logo" src="/logo.png" width="38" height="38" alt={`${site.name} — home`} decoding="async" />
    </a>

    <nav class="nav" aria-label="Primary">
      <ul id="nav-list" class="nav-list">
        {site.nav.map((item) => (
          <li>
            <a href={item.href} class:list={['nav-link', isActive(item.href) && 'is-active']} aria-current={isActive(item.href) ? 'page' : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <button id="theme-btn" class="icon-btn" type="button" aria-label="Toggle color theme" title="Toggle theme">
        <svg class="ic-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <circle cx="12" cy="12" r="4.2" /><path d="M12 2v2.5M12 19.5V22M4.2 4.2l1.8 1.8M18 18l1.8 1.8M2 12h2.5M19.5 12H22M4.2 19.8L6 18M18 6l1.8-1.8" />
        </svg>
        <svg class="ic-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
          <path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z" />
        </svg>
      </button>

      <button id="menu-btn" class="icon-btn menu-btn" type="button" aria-label="Menu" aria-expanded="false" aria-controls="nav-list">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
      </button>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-btn');
    if (btn) btn.addEventListener('click', function () {
      var cur = document.documentElement.getAttribute('data-theme');
      if (!cur) cur = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      var next = cur === 'dark' ? 'light' : 'dark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (e) {}
    });
    var menu = document.getElementById('menu-btn');
    var head = document.querySelector('.site-head');
    if (menu && head) menu.addEventListener('click', function () {
      var open = head.classList.toggle('nav-open');
      menu.setAttribute('aria-expanded', String(open));
    });
    document.querySelectorAll('.nav-link').forEach(function (a) {
      a.addEventListener('click', function () {
        if (head) head.classList.remove('nav-open');
        if (menu) menu.setAttribute('aria-expanded', 'false');
      });
    });
  })();
</script>

<style>
  .site-head {
    position: sticky; top: 0; z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--rule);
  }
  .head-in { display: flex; align-items: center; justify-content: space-between; height: 60px; }
  /* Fixed square viewport; the mark is scaled up inside it to crop the logo's
     transparent padding so the "BG" reads clearly at small sizes. */
  .wordmark { display: inline-grid; place-items: center; width: 38px; height: 38px; overflow: hidden; }
  .wm-logo { width: 100%; height: 100%; display: block; transform: scale(1.4); }

  .nav { display: flex; align-items: center; gap: 0.35rem; }
  .nav-list { list-style: none; display: flex; align-items: center; gap: 0.25rem; margin: 0; padding: 0; }
  /* Underline slide: the accent is an absolutely-positioned bar, so active and
     inactive links share the exact same box — no vertical shift, no offset. */
  .nav-link {
    position: relative;
    font-family: var(--font-mono); font-size: var(--t-small); letter-spacing: 0.02em;
    color: var(--fg-2); padding: 0.5rem 0.4rem;
    transition: color var(--dur-1) var(--ease);
  }
  .nav-link::after {
    content: ""; position: absolute; left: 0.4rem; right: 0.4rem; bottom: 2px; height: 2px;
    background: var(--verm); border-radius: 1px;
    transform: scaleX(0); transform-origin: left center;
    transition: transform var(--dur-1) var(--ease);
  }
  .nav-link:hover { color: var(--fg); }
  .nav-link:hover::after,
  .nav-link.is-active::after { transform: scaleX(1); }
  .nav-link.is-active { color: var(--fg); }

  .icon-btn {
    display: inline-grid; place-items: center; width: 38px; height: 38px;
    border-radius: var(--r); color: var(--fg-2);
    transition: color var(--dur-1) var(--ease), background var(--dur-1) var(--ease);
  }
  .icon-btn:hover { color: var(--fg); background: var(--surface); }
  .icon-btn svg { width: 18px; height: 18px; }
  .ic-moon { display: none; }
  :root[data-theme='light'] .ic-sun { display: none; }
  :root[data-theme='light'] .ic-moon { display: block; }
  @media (prefers-color-scheme: light) {
    :root:not([data-theme]) .ic-sun { display: none; }
    :root:not([data-theme]) .ic-moon { display: block; }
  }
  .menu-btn { display: none; }

  @media (max-width: 620px) {
    .menu-btn { display: inline-grid; }
    .nav-list {
      position: absolute; top: 60px; left: 0; right: 0;
      flex-direction: column; align-items: stretch; gap: 0;
      background: var(--bg); border-bottom: 1px solid var(--rule);
      padding: 0.5rem clamp(1.25rem, 4vw, 2.5rem) 1rem;
      transform: translateY(-8px); opacity: 0; pointer-events: none;
      transition: opacity var(--dur-1) var(--ease), transform var(--dur-1) var(--ease);
    }
    .nav-open .nav-list { transform: translateY(0); opacity: 1; pointer-events: auto; }
    .nav-link { padding: 0.7rem 0.5rem; font-size: var(--t-body); }
    .nav-link::after { display: none; }
  }
</style>
